# marc-os pacman packages. Format: name<TAB>description. Blank and #-lines skipped.
xorg-server	X.Org display server
xorg-xinit	startx and xinit helpers
xorg-xrandr	RandR CLI for display config
xorg-xsetroot	Root window utility
xorg-xset	X server preferences CLI (used by i3 idle config)
pipewire	Modern audio/video server
pipewire-pulse	PulseAudio replacement for PipeWire
pipewire-alsa	ALSA compatibility for PipeWire
pipewire-jack	JACK compatibility for PipeWire
wireplumber	PipeWire session manager
alsa-utils	Userspace ALSA utilities
pavucontrol	PulseAudio/PipeWire volume control GUI
brightnessctl	Backlight and LED brightness control
acpi	Battery and thermal info CLI
noto-fonts	Google Noto base fonts
noto-fonts-emoji	Google Noto color emoji
ttf-hack	Hack monospace font
ttf-jetbrains-mono	JetBrains Mono font
ttf-jetbrains-mono-nerd	JetBrains Mono patched with Nerd Font glyphs
ttf-dejavu	DejaVu fallback fonts
ttf-liberation	Liberation fallback fonts
zsh	Z shell
zsh-completions	Extra zsh completions
zsh-syntax-highlighting	zsh syntax highlighting
zsh-autosuggestions	zsh autosuggestions
neovim	Hyperextensible Vim-based editor
i3-wm	i3 tiling window manager
i3status	Status bar generator for i3
i3lock	Screen locker
xss-lock	Screensaver/lock dispatcher for X11
dunst	Lightweight notification daemon
picom	X11 compositor
rofi	Application launcher and dmenu replacement
polkit-gnome	GNOME polkit authentication agent
autorandr	Auto-apply display profiles
arandr	GUI for xrandr
alacritty	GPU-accelerated terminal emulator
qutebrowser	Keyboard-driven Qt browser
firefox	Mozilla Firefox
chromium	Open-source Chromium browser
yazi	Terminal file manager
lf	Terminal file manager
ranger	VIM-inspired file manager
gvfs	Virtual filesystem layer (trash, MTP, network mounts)
gvfs-mtp	MTP backend for gvfs (Android phones)
maim	Screenshot utility
slop	Region selection for screenshots
xclip	X11 clipboard CLI
xdotool	X11 keyboard/mouse simulator
clipmenu	Clipboard manager using dmenu/rofi
playerctl	MPRIS media player CLI
xdg-utils	XDG desktop integration scripts
xdg-user-dirs	Manage XDG user directories
xdg-desktop-portal	Portals API for sandboxed/browser screen share and file picker
xdg-desktop-portal-gtk	GTK backend for xdg-desktop-portal
networkmanager	Network connection manager
bluez	Bluetooth protocol stack
bluez-utils	Bluetooth utilities (bluetoothctl)
openssh	SSH client and server
fzf	Command-line fuzzy finder
ripgrep	Fast recursive grep
fd	Fast find replacement
bat	cat clone with syntax highlighting
eza	Modern ls replacement
jq	JSON processor
yq	YAML/XML/TOML processor
github-cli	GitHub command-line tool
git-delta	Syntax-highlighting pager for git diffs
lazygit	Terminal UI for git
tmux	Terminal multiplexer
btop	Resource monitor
httpie	Human-friendly HTTP client
bind	DNS tools including dig
nmap	Network exploration and security scanner
wget	Non-interactive network downloader
rsync	Incremental file transfer
unzip	ZIP archive extractor
zip	ZIP archive creator
p7zip	7z/rar/etc archive tool
tree	Directory tree viewer
python-pipx	Install Python apps in isolated venvs
uv	Fast Python package and project manager
docker	Container runtime
docker-compose	Multi-container Docker apps
shellcheck	Static analysis for shell scripts
shfmt	Shell script formatter
